# Environment variables — copy to .env and fill in real values
# .env is NOT committed to git

# CV PDF direct Cloudinary URL
VITE_CV_URL=https://res.cloudinary.com/YOUR_CLOUD/image/upload/v.../CV/your-cv.pdf

# Contact info (optional override — encoded in source by default)
# VITE_CONTACT_EMAIL=your-email@example.com
# VITE_CONTACT_PHONE=+1234567890
